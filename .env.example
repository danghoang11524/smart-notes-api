# AWS region deploy tới
AWS_REGION=ap-southeast-1

# Tên bảng DynamoDB (được set tự động qua SAM Environment Variables khi deploy,
# giá trị dưới đây chỉ dùng khi chạy local với `npm start`)
NOTES_TABLE_NAME=Notes-dev

# Tên bucket S3 (được set tự động qua SAM Environment Variables khi deploy,
# giá trị dưới đây chỉ dùng khi chạy local với `npm start`)
NOTES_BUCKET_NAME=smart-notes-storage-xxxxxxxxxxxx-dev

# Port khi chạy Express server ở local (npm start)
PORT=3000

{
  "name": "smart-notes-api",
  "version": "1.0.0",
  "description": "Smart Notes API - Serverless REST API (API Gateway + Lambda + DynamoDB + S3)",
  "type": "module",
  "main": "src/lambda.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "build": "sam build",
    "deploy": "sam deploy --guided",
    "deploy:fast": "sam deploy"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.658.0",
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/lib-dynamodb": "^3.658.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^2.0.1",
    "serverless-http": "^3.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "aws-sdk-client-mock": "^4.0.1",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
